@startuml ptp_machine_data_publishing

title PTPMachine: Periodic Data Publishing Workflow

hide footbox

autonumber "<font color=red><b>[00]"

legend top left
    |= Color           |= Description         |
    | <#PaleTurquoise> | MessageBroker        |
    | <#Wheat>         | PtpMachine           |
    | <#LightBlue>     | ControlFlowDivider   |
endlegend

participant "PtpMachine" as ptp_machine #Wheat
participant "PtpEngine" as engine #Wheat
participant "MessageBroker" as broker #PaleTurquoise
participant "ControlFlowDivider" as cfd #LightBlue

loop periodic (e.g., every 50ms)
    activate ptp_machine
    ptp_machine -> ptp_machine : PeriodicTask()

    ptp_machine -> engine : ReadPTPSnapshot()
    activate engine
    note right of engine
        Retrieve current PTP data:
        - PTP time
        - Synchronization status
        - Additional metadata
    end note
    engine --> ptp_machine : PtpTimeInfo
    deactivate engine

    ptp_machine -> ptp_machine : Publish(data)
    ptp_machine -> broker : publish_callback_(data)
    activate broker
    note right
        Invoke registered callback
        to publish via MessageBroker
    end note

    broker -> broker : OnNewData("in_ptp_data", data)
    broker -> cfd : subscription.callback_(data)
    activate cfd
    cfd -> cfd : OnMessage(data)
    cfd --> broker
    deactivate cfd
    broker --> ptp_machine
    deactivate broker
    deactivate ptp_machine
end

@enduml
