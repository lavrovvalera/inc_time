@startuml ipc_receive_seq_diagram

title IPC Machine: Receiving new TimeInfo data

hide footbox

autonumber "<font color=red><b>[00]"
autoactivate on

legend top left
    |= Color        |= Description                  |
    |<#LightPink>   | IPC components                |
    |<#WhiteSmoke>  | Shared Memory                 |
    |<#LightSalmon> | Client Application            |
endlegend

box mw::time::svt #e6ffe6
    participant "Business logic" as mw_worker #LightSalmon
    participant "IPCMachine:receiver" as ipc_receiver #LightPink
end box

participant "shmem" as shared_memory #WhiteSmoke

mw_worker -> ipc_receiver: receive()
ipc_receiver -> shared_memory: read()
shared_memory --> ipc_receiver: TimeInfo
ipc_receiver --> mw_worker: TimeInfo

@enduml
