@startuml control_flow_divider_workflow

title ControlFlowDivider: Main Workflow

hide footbox

autonumber "<font color=red><b>[00]"

legend top left
    |= Color        |= Description                  |
    |<#LightCyan>   | TimeDaemon members            |
    |<#PaleTurquoise> | MessageBroker               |
    |<#LightBlue>   | ControlFlowDivider            |
    |<#Lavender>    | VerificationMachine           |
    |<#LightPink>   | IPC components                |
endlegend

participant "VerificationMachine" as vm #Lavender
participant "MessageBroker" as broker #PaleTurquoise
participant "ControlFlowDivider" as cfd #LightBlue
participant "IPCPublisher" as ipc #LightPink

== Data Arrival ==

vm -> broker : publish("validated_ptp_data", data)
activate vm
activate broker
broker -> cfd : OnMessage(data)
activate cfd

cfd -> cfd : Buffer data and\nnotify event thread
note right
    Data queued in
    circular buffer
end note

cfd --> broker
deactivate cfd
broker --> vm
deactivate broker
deactivate vm

== Event Processing ==

loop process all buffered data
    cfd -> cfd : OnEvent()
    activate cfd
    note right of cfd
        Process all available data:
        - Pop from buffer
        - Store as last_data_
        - Publish to subscribers
    end note

    cfd -> broker : publish_callback_(data)
    activate broker
    broker -> ipc : notify subscribers in separate thread
    activate ipc
    ipc --> broker
    deactivate ipc
    broker --> cfd
    deactivate broker
    deactivate cfd
end

== Timeout Handling ==

alt if no new data arrives
    cfd -> cfd : OnTimeout()
    activate cfd
    cfd -> broker : publish_callback_(last_data_)
    activate broker
    note right of cfd
        Republish last known data
        to maintain timing consistency
    end note
    broker -> ipc : notify subscribers in separate thread
    activate ipc
    ipc --> broker
    deactivate ipc
    broker --> cfd
    deactivate broker
    deactivate cfd
end

@enduml
