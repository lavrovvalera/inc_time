@startuml verification_machine_verification_sequence_diagram

title VerificationMachine: Validation Workflow

hide footbox

autonumber "<font color=red><b>[00]"

legend top left
    |= Color        |= Description                   |
    |<#PaleTurquoise> | MessageBroker                |
    |<#LightBlue>   | ControlFlowDivider             |
    |<#Lavender>    | VerificationMachine            |
    |<#LightPink>   | IPC components                 |
endlegend

participant "ControlFlowDivider" as cfd #LightBlue
participant "MessageBroker" as broker #PaleTurquoise
participant "VerificationMachine" as verif_machine #Lavender
participant "Validator Pipeline" as pipeline #Lavender
participant "IPCPublisher" as ipc #LightPink

cfd -> broker : publish("raw_ptp_data", data)
activate broker
broker -> verif_machine : OnMessage(data)
activate verif_machine

verif_machine -> pipeline : Process(data)
activate pipeline
note right of pipeline
    Chain of Responsibility:
    Each validator processes data
    and passes to next stage:
    1. SynchronizationValidator
    2. TimeoutValidator
    3. TimeJumpsValidator
end note

pipeline -> pipeline : Stage 1: DoValidation(data)
pipeline -> pipeline : Stage 2: DoValidation(data)
pipeline -> pipeline : Stage 3: DoValidation(data)

pipeline --> verif_machine : validated data
deactivate pipeline

verif_machine -> verif_machine : Publish(data)
verif_machine -> broker : publish_callback_(data)
deactivate verif_machine
broker -> broker : OnNewData("validated_ptp_data", data)
broker -> ipc : subscription.callback_(data)
activate ipc
ipc --> broker
deactivate ipc
broker --> cfd
deactivate broker

@enduml
